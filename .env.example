# Content-Creator environment configuration
# Copy to `.env.local` and fill in real values. `.env.local` is git-ignored.

# PostgreSQL connection used by the app (Drizzle + Better Auth).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/content_creator

# Separate database for the test suite (Vitest). Falls back to DATABASE_URL when unset.
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/content_creator_test

# Better Auth session secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-bytes-base64

# Public base URL for Better Auth (callbacks, cookies).
BETTER_AUTH_URL=http://localhost:3000

# AES-256-GCM master key for the token vault — 32-byte key, base64-encoded.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-with-32-bytes-base64

# OAuth provider mode: "mock" (default, no approved app needed) or "real".
OAUTH_PROVIDER_MODE=mock

# Meta (Facebook/Instagram) OAuth app credentials (only needed when OAUTH_PROVIDER_MODE=real).
META_CLIENT_ID=
META_CLIENT_SECRET=

# LinkedIn OAuth app credentials (only needed when OAUTH_PROVIDER_MODE=real).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# R2 (Cloudflare) or S3-compatible — media storage
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=content-creator-media

# --- Local media testing (MinIO, enabled in docker-compose.yml) ---
# Uncomment and set these in .env.local to test uploads without an R2 account:
# R2_ENDPOINT=http://localhost:9000
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_BUCKET_NAME=content-creator-media
# (bucket "content-creator-media" is auto-created by the cc-minio-init service)

# Redis connection for BullMQ (background scheduler).
REDIS_URL=redis://localhost:6379

# Enable TLS for managed Redis (Upstash, Redis Cloud, ElastiCache).
# REDIS_TLS=true

# Publisher mode: "fake" (default, no real API calls) or "real" (Phase 4+).
PUBLISHER_MODE=fake
